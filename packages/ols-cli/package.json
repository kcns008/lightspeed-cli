{
	"name": "@ols-cli/lightspeed",
	"version": "0.1.0",
	"description": "OpenShift Lightspeed CLI — AI-powered assistant for OpenShift from your terminal. Built on pi-mono.",
	"type": "module",
	"bin": {
		"ols": "dist/cli.js"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist",
		"skills",
		"CHANGELOG.md",
		"README.md"
	],
	"scripts": {
		"clean": "rm -rf dist",
		"build": "tsc -p tsconfig.build.json && npm run copy-assets",
		"copy-assets": "mkdir -p dist/skills && cp -r skills/* dist/skills/ 2>/dev/null; cp src/ols-system-prompt.md dist/ 2>/dev/null; true",
		"prepublishOnly": "npm run clean && npm run build"
	},
	"keywords": [
		"openshift",
		"lightspeed",
		"ols",
		"kubernetes",
		"cli",
		"ai-agent",
		"assistant",
		"terminal",
		"devops"
	],
	"author": "Chin (kcns008)",
	"license": "Apache-2.0",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kcns008/lightspeed-cli.git"
	},
	"homepage": "https://github.com/kcns008/lightspeed-cli#readme",
	"bugs": {
		"url": "https://github.com/kcns008/lightspeed-cli/issues"
	},
	"engines": {
		"node": ">=20.6.0"
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	},
	"dependencies": {
		"@mariozechner/pi-agent-core": "^0.66.1",
		"@mariozechner/pi-ai": "^0.66.1",
		"@mariozechner/pi-tui": "^0.66.1",
		"@ols-cli/client": "^0.1.0",
		"chalk": "^5.5.0",
		"undici": "^7.19.1"
	}
}
